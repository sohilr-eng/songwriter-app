{
  "expo": {
    "name": "songwriter-app-2026",
    "slug": "songwriter-app-2026",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "songwriterapp2026",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "userInterfaceStyle": "light",
      "supportsTablet": true,
      "infoPlist": {
        "UTExportedTypeDeclarations": [
          {
            "UTTypeIdentifier": "com.songwriter.song",
            "UTTypeDescription": "Songwriter Song",
            "UTTypeConformsTo": [
              "public.data"
            ],
            "UTTypeTagSpecification": {
              "public.filename-extension": [
                "swsong"
              ],
              "public.mime-type": "application/x-songwriter-song"
            }
          }
        ],
        "CFBundleDocumentTypes": [
          {
            "CFBundleTypeName": "Songwriter Song",
            "LSHandlerRank": "Owner",
            "LSItemContentTypes": [
              "com.songwriter.song"
            ]
          }
        ]
      }
    },
    "android": {
      "userInterfaceStyle": "light",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "mimeType": "application/x-songwriter-song"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Songwriter to access your microphone for voice memos."
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
